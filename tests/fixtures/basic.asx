# small demo case with three particles

particle_shape sphere

simulation_domain low (-0.1, -0.1, -1) high (1, 1, 1)

materials {m1}

material_properties m1 youngsModulus 5e6 poissonsRatio 0.45 coefficientRestitution 0.3 coefficientFriction 0.5 density 2500

particle_contact_model normal hertz tangential history
wall_contact_model normal hertz tangential history

simulation_timestep 1e-5

particle_template id pt material m1 radius 0.0499

create_particles pt single 0.1 0   0 velocity  1 0 0
create_particles pt single 0.2 0   0 velocity -1 0 0
create_particles pt single 0.3 0.3 0 velocity -1 0 0

mesh id plate file meshes/plate.stl material m1 translate (0, 0, 0.05)

write_output_timestep 1e-4
write_to_terminal_timestep 1e-4

output_settings

simulate time 1e-1
