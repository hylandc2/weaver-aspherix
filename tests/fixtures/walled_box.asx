particle_shape sphere
simulation_domain low (0, 0, 0) high (0.1, 0.1, 0.1)

neighbor_list skin_size 0.002 stencil_check no

materials {m1}
material_properties m1 youngsModulus 5e6 poissonsRatio 0.3 coefficientRestitution 0.4 coefficientFriction 0.5 density 2500

particle_contact_model normal hertz tangential history
wall_contact_model normal hertz tangential history

simulation_timestep 1e-5

primitive_wall id wx0 material m1 type plane normal_axis x offset 0
primitive_wall id wx1 material m1 type plane normal_axis x offset 0.1
primitive_wall id wy0 material m1 type plane normal_axis y offset 0
primitive_wall id wy1 material m1 type plane normal_axis y offset 0.1
primitive_wall id wz0 material m1 type plane normal_axis z offset 0
primitive_wall id wz1 material m1 type plane normal_axis z offset 0.1

particle_template id pt material m1 radius 0.005
create_particles pt single 0.02 0.05 0.05 velocity -2 0 0
create_particles pt single 0.05 0.08 0.05 velocity 0 2 0
create_particles pt single 0.05 0.05 0.02 velocity 0 0 -2

write_output_timestep 1e-3
write_to_terminal_timestep 1e-3
output_settings

simulate time_steps 2000
